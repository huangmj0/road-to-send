{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huangmj0.github.io/road-to-send/schema/v10.json",
  "title": "Road to Send protocol v10",
  "type": "object",
  "required": ["version", "features", "activities", "config"],
  "properties": {
    "version": { "const": 10 },
    "features": { "type": "array", "items": { "type": "string" } },
    "activities": { "type": "array", "items": { "$ref": "#/$defs/activity" } },
    "config": { "anyOf": [{ "$ref": "#/$defs/settings" }, { "type": "null" }] },
    "configErrors": { "type": "array", "items": { "$ref": "#/$defs/errorDetail" } },
    "serverDate": { "$ref": "#/$defs/date" },
    "timeZone": { "type": "string" },
    "fetchedAt": { "type": "string" }
  },
  "$defs": {
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "participant": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 30 }
      },
      "additionalProperties": false
    },
    "settings": {
      "type": "object",
      "required": ["startDate", "tripDate", "goal", "crew"],
      "properties": {
        "startDate": { "$ref": "#/$defs/date" },
        "tripDate": { "$ref": "#/$defs/date" },
        "goal": { "type": "integer", "minimum": 50, "maximum": 10000 },
        "crew": { "type": "array", "items": { "$ref": "#/$defs/participant" } }
      },
      "additionalProperties": false
    },
    "activity": {
      "type": "object",
      "required": ["id", "name", "type", "points", "date", "createdAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1, "maxLength": 30 },
        "type": { "enum": ["climb", "exercise", "mobility", "bounty"] },
        "category": { "enum": ["", "climb", "exercise", "mobility"] },
        "points": { "type": "integer", "minimum": 0, "maximum": 3 },
        "date": { "$ref": "#/$defs/date" },
        "createdAt": { "type": "string" },
        "hardestGrade": { "enum": ["", "V0", "V1", "V2", "V3", "V4", "V5", "V6", "V7", "V8", "V9", "V10", "V11", "V12", "V13", "V14", "V15", "V16", "V17"] },
        "bountyId": { "type": "string", "maxLength": 40 },
        "bountyTitle": { "type": "string", "maxLength": 60 },
        "note": { "type": "string", "maxLength": 120 }
      },
      "additionalProperties": false
    },
    "errorDetail": {
      "type": "object",
      "required": ["field", "reason"],
      "properties": {
        "field": { "type": "string" },
        "reason": { "type": "string" },
        "cell": { "type": "string" },
        "value": { "type": "string" }
      }
    }
  }
}
